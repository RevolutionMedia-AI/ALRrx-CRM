# ===========================================
# ALRrx CRM — Environment Variables Example
# Copy this file to .env and fill your values
# ===========================================
#
# --- SSH Tunnel (Linux server where MariaDB runs) ---
SSH_HOST=192.168.1.100
SSH_PORT=22
SSH_USERNAME=root
SSH_PASSWORD=
SSH_PRIVATE_KEY_PATH=
SSH_PRIVATE_KEY_PASSPHRASE=
SSH_REMOTE_HOST=127.0.0.1
SSH_REMOTE_PORT=3306
#
# --- MariaDB (database on the Linux server) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=asterisk
DB_USER=vicidial
DB_PASSWORD=
#
# --- JWT (ALRrx) ---
JWT__KEY=change-this-to-a-secure-random-key
JWT__ISSUER=ALRrx
JWT__AUDIENCE=ALRrx

# ===========================================
# Slice (separate enterprise, same container)
# ===========================================
#
# --- JWT (Slice) — must be different from ALRrx ---
Jwt__Key=change-this-to-a-different-secure-random-key
Jwt__Issuer=SliceApi
Jwt__Audience=SliceClients
#
# --- Google OAuth (Slice login) ---
# Create a SEPARATE OAuth client in Google Cloud Console.
# Restrict the same way: only @revolutionmedia.ai users.
Google__ClientId=your-slice-client-id.apps.googleusercontent.com
#
# --- Resend (Slice email delivery, optional) ---
Resend__ApiKey=re_xxxxxxxxxxxx
Resend__FromEmail=reports@revolutionmedia.ai
