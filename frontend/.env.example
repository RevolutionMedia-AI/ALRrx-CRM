# Google OAuth Client ID - get this from Google Cloud Console
# https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=your-client-id-here.apps.googleusercontent.com

# Slice uses a SEPARATE Google OAuth Client (different project, same domain restriction).
# Optional: if absent, Slice login falls back to email+password only.
VITE_GOOGLE_CLIENT_ID_SLICE=your-slice-client-id-here.apps.googleusercontent.com
