{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "backend/ALRrx.Api/Dockerfile"
  },
  "deploy": {
    "numReplicas": 1,
    "healthcheckPath": "/api/dashboard/summary?period=Today",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE"
  }
}
